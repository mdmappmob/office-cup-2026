# Obtenha uma chave gratuita em https://www.football-data.org/client/register
FOOTBALL_API_KEY=sua_chave_aqui
# ID da competição (2000 = Copa do Mundo FIFA)
FOOTBALL_COMPETITION_ID=2000

# E-mail do admin (admin fixo)
VITE_ADMIN_EMAIL=mdm.appmob@gmail.com

# Supabase (público, pode versionar)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# Supabase (servidor — NÃO versionar, manter só no .env local e Vercel)
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
